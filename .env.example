# ============================================================
# Variables de entorno para desarrollo local
# Copiar este archivo como .env y completar con tus valores:
#   cp .env.example .env
# ============================================================

# Base de datos MySQL
DB_ENDPOINT=mysql
DB_PORT=3306
DB_NAME=prueba3_db
DB_USERNAME=appuser
DB_PASSWORD=changeme123

# Amazon ECR (usado en pipelines de CI/CD)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012
ECR_REPO_VENTAS=ventas-api
ECR_REPO_DESPACHOS=despachos-api
ECR_REPO_FRONTEND=frontend-despacho
